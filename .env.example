# WhatsApp SBTE Bot environment configuration
# Copy this file to ".env" and adjust as needed. Never commit real credentials.

# Session identifier. Allows multiple accounts in the future by giving each a unique name.
# The auth state for this account is stored under sessions/<SESSION_ID>/
SESSION_ID=default

# PostgreSQL database connection string (required for Vercel/Supabase/Neon deployment)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://username:password@localhost:5432/dbname?schema=public"

# Frontend API URL (leave empty for development, use proxy)
# For Vercel production: https://your-app.vercel.app
VITE_API_URL=""

# Logging level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Optional: override the WhatsApp web version (leave empty for library default)
WA_VERSION=

# Optional: override the browser user agent (leave empty for library default)
USER_AGENT=
